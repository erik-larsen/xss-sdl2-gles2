extern int xss_run_screenhack (struct xscreensaver_function_table *,
                               int, char **);
extern struct xscreensaver_function_table
  @HACK_PREFIX@_xscreensaver_function_table;

#ifdef __EMSCRIPTEN__
int
main (void)
{
  int argc; char **argv = xss_web_args (&argc);
  return xss_run_screenhack (&@HACK_PREFIX@_xscreensaver_function_table,
                             argc, argv);
}
#else
